NODE_ENV=development
PORT=3001

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_ANON_KEY=your-anon-key

# Database (Direct connection for Drizzle ORM)
DATABASE_URL=postgresql://postgres:password@db.your-project.supabase.co:5432/postgres

# Database Schema (for multi-tenancy)
# Each project should use its own schema (not 'public')
# Example: attendance_system, project_alpha, countrylab_lms, etc.
DATABASE_SCHEMA=countrylab_lms

# JWT
JWT_SECRET=your-super-secret-jwt-key-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret
JWT_REFRESH_EXPIRES_IN=7d

# Redis (for BullMQ)
REDIS_URL=redis://localhost:6379

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your-app-password
FROM_EMAIL=info@countrylab.com.ng
FROM_NAME=Countrylab Laboratory
COMPANY_EMAIL=info@countrylab.com.ng

# File Storage
SUPABASE_STORAGE_BUCKET=countrylab-files

# App
FRONTEND_URL=http://localhost:5173
APP_NAME=Countrylab LMS
